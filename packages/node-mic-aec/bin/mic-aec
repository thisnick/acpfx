#!/usr/bin/env node

"use strict";

const { spawnSync } = require("child_process");
const { join } = require("path");
const { existsSync } = require("fs");

function getBinaryPath() {
  // Allow override via env var (for local development)
  if (process.env.MIC_AEC_BINARY_PATH) {
    return process.env.MIC_AEC_BINARY_PATH;
  }

  const ext = process.platform === "win32" ? ".exe" : "";
  const binName = `mic-aec-${process.platform}-${process.arch}${ext}`;
  const binPath = join(__dirname, binName);

  if (!existsSync(binPath)) {
    throw new Error(
      `Could not find the mic-aec binary for your platform (${process.platform} ${process.arch}).\n` +
      `Expected: ${binPath}\n` +
      `The postinstall script may have failed. Try reinstalling:\n` +
      `  npm install @acpfx/mic-aec\n` +
      `Or set MIC_AEC_BINARY_PATH to a local build.`
    );
  }

  return binPath;
}

const binPath = getBinaryPath();
const { status } = spawnSync(binPath, process.argv.slice(2), {
  stdio: "inherit",
});
process.exitCode = status !== null ? status : 1;
