{
  "name": "acpfx",
  "version": "0.2.0",
  "private": true,
  "description": "Observable DAG-based voice pipeline for ACP agents",
  "type": "module",
  "scripts": {
    "build": "node scripts/build.js",
    "build:native": "cargo build --release -p acpfx-orchestrator",
    "check": "tsc --noEmit",
    "test": "node --test dist/tests/**/*.test.js",
    "start": "./target/release/acpfx run",
    "start:headless": "./target/release/acpfx run"
  },
  "keywords": [
    "acp",
    "voice",
    "pipeline",
    "cli"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@acpfx/core": "workspace:*",
    "speaker": "^0.5.5",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "esbuild": "^0.25.0",
    "typescript": "^5.7.0",
    "zod": "^4.3.6"
  },
  "packageManager": "pnpm@10.29.3",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "speaker"
    ]
  }
}
