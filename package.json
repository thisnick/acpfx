  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.14",
    "ink-testing-library": "^4.0.0",
    "typescript": "^5.7.0"
  },
  "packageManager": "pnpm@10.29.3"
}
