{
  "name": "acpfx",
  "version": "0.2.0",
  "private": true,
  "description": "Observable DAG-based voice pipeline for ACP agents",
  "type": "module",
  "scripts": {
    "build": "node scripts/build.js",
    "build:native": "node -e \"const p=process.platform;const f=p==='darwin'?'metal':'';const c='cargo build --workspace'+(f?' --features '+f:'');require('child_process').execSync(c,{stdio:'inherit'})\"",
    "check": "tsc --noEmit",
    "test": "pnpm -r --if-present test",
    "test:integration": "node --test dist/tests/**/*.test.js",
    "start": "./target/debug/acpfx run",
    "start:headless": "./target/debug/acpfx run --headless",
    "onboard": "./target/debug/acpfx onboard",
    "changeset": "changeset",
    "version-packages": "changeset version && node scripts/sync-cargo-versions.js",
    "release": "pnpm build && changeset publish"
  },
  "keywords": [
    "acp",
    "voice",
    "pipeline",
    "cli"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@acpfx/core": "workspace:*",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.0",
    "@types/node": "^22.0.0",
    "esbuild": "^0.25.0",
    "typescript": "^5.7.0",
    "zod": "^4.3.6"
  },
  "packageManager": "pnpm@10.29.3",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
