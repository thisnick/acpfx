{
  "name": "acpfx",
  "version": "0.2.0",
  "description": "Observable DAG-based voice pipeline for ACP agents",
  "type": "module",
  "bin": {
    "acpfx": "dist/main.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "check": "tsc --noEmit",
